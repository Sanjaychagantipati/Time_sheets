// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model attendance_sessions {
  id           String      @id @db.VarChar(36)
  timesheet_id String      @db.VarChar(36)
  clock_in     DateTime    @db.Time(6)
  clock_out    DateTime?   @db.Time(6)
  hours        Decimal?    @db.Decimal(4, 2)
  timesheets   timesheets @relation(fields: [timesheet_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([timesheet_id])
}

model clients {
  id         Int          @id @default(autoincrement())
  name       String       @db.VarChar(100)
  code       String       @unique @db.VarChar(20)
  active     Boolean?     @default(true)
  created_at DateTime?    @default(now()) @db.Timestamp(6)
  timesheets timesheets[]
  users      users[]
}

model holidays {
  id           String    @id @db.VarChar(36)
  holiday_name String    @db.VarChar(100)
  holiday_date DateTime  @unique @db.Date
  is_active    Boolean   @default(true)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  description  String?   @db.VarChar(255)
  holiday_type String    @db.VarChar(50)
  updated_at   DateTime? @db.Timestamp(6)
}

model timesheets {
  id                  String                @id @db.VarChar(36)
  user_id             String                @db.VarChar(36)
  client_id           Int
  date                DateTime              @db.Date
  clock_in            DateTime              @db.Time(6)
  clock_out           DateTime?             @db.Time(6)
  hours               Decimal?              @db.Decimal(4, 2)
  notes               String?
  location            String?               @db.VarChar(255)
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  ip_address          String?               @db.VarChar(45)
  user_agent          String?
  browser             String?               @db.VarChar(50)
  operating_system    String?               @db.VarChar(50)
  device_type         String?               @db.VarChar(30)
  screen_resolution   String?               @db.VarChar(20)
  attendance_sessions attendance_sessions[]
  clients             clients               @relation(fields: [client_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users               users                 @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id])
  @@index([client_id])
  @@index([date])
  @@index([user_id, date])
}

model users {
  id                 String               @id @db.VarChar(36)
  name               String               @db.VarChar(100)
  username           String               @unique @db.VarChar(50)
  password_hash      String               @db.VarChar(255)
  role               String               @db.VarChar(20)
  client_id          Int?
  hourly_rate        Decimal              @default(0.00) @db.Decimal(8, 2)
  created_at         DateTime?            @default(now()) @db.Timestamp(6)
  timesheets         timesheets[]
  clients            clients?             @relation(fields: [client_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  push_subscriptions push_subscriptions[]
  leaves             leaves[]
}

model push_subscriptions {
  id         String   @id @db.VarChar(36)
  user_id    String   @db.VarChar(36)
  endpoint   String   @unique
  p256dh     String
  auth       String
  created_at DateTime @default(now()) @db.Timestamp(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id])
}

model company_settings {
  id                         String   @id @db.VarChar(36)
  office_start_time          String   @db.VarChar(5)
  office_end_time            String   @db.VarChar(5)
  clock_in_grace_period      Int      @default(30)
  clock_out_grace_period     Int      @default(0)
  clock_in_reminder_offset   Int      @default(5)
  clock_out_reminder_offset  Int      @default(10)
  attendance_recovery_enabled Boolean  @default(true)
  recovery_deadline          String   @default("23:59")
  weekend_configuration      String   @default("Saturday,Sunday")
  timezone                   String   @default("Asia/Kolkata")
  updated_at                 DateTime @default(now()) @db.Timestamp(6)
}

model leaves {
  id         String    @id @db.VarChar(36)
  user_id    String    @db.VarChar(36)
  leave_type String    @db.VarChar(50)
  start_date DateTime  @db.Date
  end_date   DateTime  @db.Date
  reason     String?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id])
  @@index([start_date, end_date])
}
